<% include ./partials/header.ejs %>
    <div class="w-full min-h-screen bg-zinc-900 text-white py-5">
        <div class="w-full px-4 flex items-center justify-between">
            <img class="w-1/4" src="/images/logo.png" alt="">
            <div class="icons -mt-2 flex gap-5 items-center">
                <i class="text-[1.4rem] ri-heart-3-line"></i>
                <i class="text-[1.4rem] ri-messenger-line"></i>
            </div>
        </div>

        <div class="relative h-[50px] flex justify-center bg-transparent">

            <div class="absolute font-semibold fixed top-5 m-2 ">Comments </div>
        </div>
        </hr>

        <div class="relative h-[calc(100vh-70px)] mb-[70px] bg-transparent overflow-y-auto">
            <% if (post.comments.length > 0) { %>
                <% post.comments.forEach((elem) => { %>
                    <div class="flex gap-4 items-start p-3 w-full border-zinc-700">

                        <!-- Profile Image -->
                        <div class="w-[60px] h-[60px] rounded-full overflow-hidden shrink-0">
                            <img class="w-full h-full object-cover" src="/images/uploads/<%= elem.user.profileImage %>" alt="">
                        </div>

                        <!-- Comment Content -->
                        <div class="flex flex-col flex-1 min-w-0">
                            <div class="flex justify-between items-center">
                                <p class="text-sm font-semibold truncate">
                                    <%= elem.user.username %>
                                </p>

                                <!-- Time -->
                                <p class="text-xs text-zinc-400 whitespace-nowrap">
                                    <% 
                  const now = new Date();
                  const diff = now - elem.date;
                  const seconds = Math.floor(diff / 1000);
                  const minutes = Math.floor(seconds / 60);
                  const hours = Math.floor(minutes / 60);
                  const days = Math.floor(hours / 24);
                %>
                                        <% if (seconds < 60) { %>
                                            <%= seconds %>s
                                                <% } else if (minutes < 60) { %>
                                                    <%= minutes %>m
                                                        <% } else if (hours < 24) { %>
                                                            <%= hours %>h
                                                                <% } else { %>
                                                                    <%= days %>d
                                                                        <% } %>
                                </p>
                            </div>

                            <div class="flex justify-between mt-1 items-start">
                                <span class="text-sm break-words w-[90%] leading-tight"><%= elem.body %></span>
                                <a href="/like/comment/<%= post._id %>/<%= elem._id %>" class="ml-2 flex items-center gap-1 shrink-0">
                                    <% if (elem.likes.indexOf(user._id) !== -1) { %>
                                        <i class="heart ri-heart-3-fill text-red-600"></i>
                                        <% } else { %>
                                            <i class="heart ri-heart-3-line"></i>
                                            <% } %>
                                                <span class="text-sm"><%= elem.likes.length %></span>
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="w-full text-center py-10">
                                <h4>No comments yet</h4>
                                <p>Be the first one!</p>
                            </div>
                            <% } %>
        </div>

        <div class=" mb-[70px] flex fixed bottom-0 w-full h-[70px] bg-zinc-900 border-t-[0.5px] border-zinc-700 ">
            <div class="title px-4 flex items-center gap-[15px]">
                <div class="w-[9vw] h-[9vw] bg-sky-100 rounded-full overflow-hidden">
                    <img class="w-full h-full object-cover" src="/images/uploads/<%=user.profileImage%>" alt="">
                </div>
                <form action="/comments/<%=post._id%>" method="post">
                    <input name="body" type="text" class="border-[1px] border-zinc-700 rounded-full bg-transparent h-12 w-[300px] p-4" placeholder="write a comment...">
                    <button type="submit"><i class="text-[1.4rem] ri-upload-fill"></i></button>
            </div>
            </form>
        </div>
    </div>

    </div>
    <% include ./partials/footer.ejs %>